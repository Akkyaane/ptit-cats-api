{
  "kind": "collectionType",
  "collectionName": "adoption_posts",
  "info": {
    "singularName": "adoption-post",
    "pluralName": "adoption-posts",
    "displayName": "AdoptionPost"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slogan": {
      "type": "string"
    },
    "shortDescription": {
      "type": "text",
      "required": false
    },
    "longDescription": {
      "type": "text",
      "required": true
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "isDuo": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "price": {
      "type": "integer",
      "required": true
    },
    "cats": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::cat.cat"
    }
  }
}
