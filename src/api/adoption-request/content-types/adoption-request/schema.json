{
  "kind": "collectionType",
  "collectionName": "adoption_requests",
  "info": {
    "singularName": "adoption-request",
    "pluralName": "adoption-requests",
    "displayName": "AdoptionRequest"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "entityStatus": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "on hold",
        "accepted",
        "refused"
      ]
    },
    "adopter": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::adopter.adopter",
      "inversedBy": "adoption_requests"
    },
    "adoption_listing": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::adoption-listing.adoption-listing",
      "inversedBy": "adoption_requests"
    }
  }
}
