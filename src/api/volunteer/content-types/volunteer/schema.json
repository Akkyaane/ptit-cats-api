{
  "kind": "collectionType",
  "collectionName": "volunteers",
  "info": {
    "singularName": "volunteer",
    "pluralName": "volunteers",
    "displayName": "Volunteer"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "lastName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "required": true
    },
    "firstName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "minLength": 5,
      "maxLength": 254
    },
    "password": {
      "type": "password",
      "required": true,
      "minLength": 14,
      "maxLength": 128
    },
    "role": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "admin",
        "manager",
        "referent"
      ]
    },
    "absences": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::absence.absence",
      "mappedBy": "volunteer"
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "volunteer"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
