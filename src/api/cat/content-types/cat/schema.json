{
  "kind": "collectionType",
  "collectionName": "cats",
  "info": {
    "singularName": "cat",
    "pluralName": "cats",
    "displayName": "Cat"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "sex": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Male",
        "Female"
      ]
    },
    "birthDate": {
      "type": "datetime",
      "required": false
    },
    "isDewormed": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "isVaccinated": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "isSterilizedOrCastrated": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "isIdentified": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "dogAffinity": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Yes",
        "No",
        "Unknown"
      ]
    },
    "catAffinity": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Yes",
        "No",
        "Unknown"
      ]
    },
    "childAffinity": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Yes",
        "No",
        "Unknown"
      ]
    },
    "livingEnvironmentType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Apartment",
        "House",
        "Other"
      ]
    },
    "keyPoints": {
      "type": "customField",
      "customField": "plugin::multi-select.multi-select",
      "default": "[]",
      "options": [
        "Enfants respectueux",
        "Foyer sans enfant en bas âge",
        "Foyer avec un chat",
        "Extérieur sécurisé"
      ]
    }
  }
}
