{
  "kind": "collectionType",
  "collectionName": "adoption_listings",
  "info": {
    "singularName": "adoption-listing",
    "pluralName": "adoption-listings",
    "displayName": "AdoptionListing"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slogan": {
      "type": "string"
    },
    "shortDescription": {
      "type": "string",
      "required": true
    },
    "longDescription": {
      "type": "text",
      "required": true
    },
    "media": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    },
    "isDuo": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "price": {
      "type": "integer",
      "required": true
    },
    "animals": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::animal.animal",
      "mappedBy": "adoption_listing"
    },
    "entityStatus": {
      "type": "enumeration",
      "required": true,
      "default": "draft",
      "enum": [
        "draft",
        "published",
        "adoption pending",
        "on hold",
        "adoption completed",
        "archived"
      ]
    }
  }
}
